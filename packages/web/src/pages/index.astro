    <button class="nav-prev" id="nav-prev" type="button" aria-label="Previous spread">‹</button>
    <button class="nav-next" id="nav-next" type="button" aria-label="Next spread">›</button>
    <div class="spread-counter" id="spread-counter" aria-live="polite"></div>

    <script
      id="samples-data"
      type="application/json"
      is:inline
      set:html={JSON.stringify(SAMPLES)}
    ></script>

    <script>
      import { analyze, getWordPhonemes } from '@harmonic-systems/early-literacy';
      import type {
        AgeBand,
        ReachWord,
        ReadabilityProfile,
        Warning,
      } from '@harmonic-systems/early-literacy';
      import {
        toEngineManuscript,
        TRIM_SIZES,
        type PageContent,
        type PagePlacement,
        type WebManuscript,
        type WebSpread,
      } from '../types.js';

      const SPREAD_COUNT = 16;
      const DEBOUNCE_MS = 250;

      interface Sample {
        ageBand: AgeBand;
        label: string;
        text: string;
      }
      const SAMPLES: Record<string, Sample> = JSON.parse(
        document.getElementById('samples-data')?.textContent ?? '{}',
      );

      function byId(id: string): HTMLElement | null {
        return document.getElementById(id);
      }

      function readPage(spread: number, side: 'left' | 'right'): PageContent {
        const sel = document.querySelector(
          `[data-page-placement="${spread}-${side}"]`,
        ) as HTMLSelectElement | null;
        const text =
          (window as unknown as {
            __pageEditors?: Record<string, { getText: () => string }>;
          }).__pageEditors?.[`${spread}-${side}`]?.getText() ?? '';
        return {
          text,
          placement: (sel?.value ?? 'text-only') as PagePlacement,
        };
      }

      function readManuscript(): WebManuscript {
        const ageSel = byId('age-band') as HTMLSelectElement | null;
        const trimSel = byId('trim-size') as HTMLSelectElement | null;
        const ageBand = (ageSel?.value as AgeBand) ?? 'picture';
        const trimKey = trimSel?.value ?? 'STANDARD_PORTRAIT';
        const trimSize = TRIM_SIZES[trimKey] ?? TRIM_SIZES.STANDARD_PORTRAIT;
        const spreads: WebSpread[] = [];
        for (let i = 1; i <= SPREAD_COUNT; i++) {
          spreads.push({
            index: i,
            leftPage: readPage(i, 'left'),
            rightPage: readPage(i, 'right'),
          });
        }
        return { ageBand, trimSize, spreads };
      }

      function fmtPercent(n: number): string {
        return `${(n * 100).toFixed(1)}%`;
      }

      function fmtNumber(n: number, digits = 2): string {
        return Number.isFinite(n) ? n.toFixed(digits) : '—';
      }

      function setText(id: string, value: string, cls = ''): void {
        const el = byId(id);
        if (!el) return;
        el.textContent = value;
        el.className = `value ${cls}`.trim();
      }

      function renderTopMetrics(profile: ReadabilityProfile): void {
        const { wordCount, wordCountTarget } = profile;
        let countClass = '';
        if (wordCount > wordCountTarget.max) countClass = 'over';
        else if (wordCountTarget.min > 0 && wordCount < wordCountTarget.min) {
          countClass = 'under';
        }
        setText('total-words', String(wordCount), countClass);
        const targetLabel =
          wordCountTarget.min > 0
            ? `${wordCountTarget.min}–${wordCountTarget.max}`
            : `≤${wordCountTarget.max}`;
        setText('total-target', targetLabel);
        setText('total-sentences', String(profile.sentenceCount));
        setText('avg-sentence', fmtNumber(profile.averageSentenceLength, 1));
        setText('sight-coverage', fmtPercent(profile.vocabulary.sightWordCoverage));
        setText('ttr', fmtNumber(profile.vocabulary.typeTokenRatio, 3));
        setText('unique-words', String(profile.vocabulary.uniqueWords));

        // Phonology
        const phon = profile.phonology;
        setText('decodability', fmtPercent(phon.decodabilityScore));
        setText('avg-syllables', fmtNumber(phon.averageSyllablesPerWord, 2));
        const syl = phon.syllableTypes;
        const entries = Object.entries(syl) as Array<[string, number]>;
        const total = entries.reduce((a, [, n]) => a + n, 0);
        if (total === 0) {
          setText('top-syllable', '—');
        } else {
          entries.sort((a, b) => b[1] - a[1]);
          const [topType, topCount] = entries[0];
          const topPct = ((topCount / total) * 100).toFixed(0);
          setText('top-syllable', `${topType} (${topPct}%)`);
        }
      }

      function renderPhonologyDetail(profile: ReadabilityProfile): void {
        const phon = profile.phonology;

        // ---- Syllable shapes ----
        const sylList = byId('syll-list');
        if (sylList) {
          sylList.innerHTML = '';
          const types = phon.syllableTypes;
          const entries = Object.entries(types) as Array<[string, number]>;
          const total = entries.reduce((a, [, n]) => a + n, 0);
          entries.sort((a, b) => b[1] - a[1]);
          for (const [type, count] of entries) {
            if (count === 0) continue;
            const pct = total > 0 ? (count / total) * 100 : 0;
            const li = document.createElement('li');
            li.className = 'syll-row';
            const label = document.createElement('span');
            label.className = 'syll-label';
            label.textContent = type;
            const bar = document.createElement('span');
            bar.className = 'syll-bar';
            const fill = document.createElement('span');
            // CCVC and CVCC are more complex shapes — give the bar an
            // accent color to signal that they raise reading difficulty.
            fill.className = `syll-fill${type === 'CCVC' || type === 'CVCC' || type === 'other' ? ' complex' : ''}`;
            fill.style.width = `${pct}%`;
            bar.appendChild(fill);
            const pctSpan = document.createElement('span');
            pctSpan.className = 'syll-pct';
            pctSpan.textContent = `${pct.toFixed(0)}%`;
            li.append(label, bar, pctSpan);
            sylList.appendChild(li);
          }
        }

        // ---- Phonemes by acquisition age ----
        const phonList = byId('phoneme-by-age');
        if (phonList) {
          phonList.innerHTML = '';
          const inv = phon.phonemeInventory;
          if (inv.length === 0) {
            const empty = document.createElement('li');
            empty.className = 'phon-age-row';
            const lbl = document.createElement('span');
            lbl.className = 'phon-age';
            lbl.textContent = '—';
            const ph = document.createElement('span');
            ph.className = 'phon-phonemes';
            ph.style.fontStyle = 'italic';
            ph.style.color = 'var(--taupe)';
            ph.textContent = 'Type into a page to see the inventory.';
            empty.append(lbl, ph);
            phonList.appendChild(empty);
            return;
          }
          // Group by floor(age) with 6+ catchall. Sort phonemes by count
          // within each group so the most prominent show first.
          const groups = new Map<number, typeof inv>();
          for (const p of inv) {
            const age = Math.min(Math.floor(p.acquisitionAge), 6);
            const arr = groups.get(age) ?? [];
            arr.push(p);
            groups.set(age, arr);
          }
          const sortedAges = [...groups.keys()].sort((a, b) => a - b);
          for (const age of sortedAges) {
            const phonemes = groups.get(age)!.slice().sort((a, b) => b.count - a.count);
            const li = document.createElement('li');
            li.className = 'phon-age-row';
            const label = document.createElement('span');
            const ageClass =
              age >= 6 ? 'phon-age latest' : age >= 5 ? 'phon-age late' : 'phon-age';
            label.className = ageClass;
            label.textContent = age >= 6 ? 'age 6+' : `age ${age}`;
            const ph = document.createElement('span');
            ph.className = 'phon-phonemes';
            for (const p of phonemes) {
              const chip = document.createElement('button');
              chip.type = 'button';
              chip.className = `phon-chip${activePhonemes.has(p.phoneme) ? ' active' : ''}`;
              chip.dataset.phoneme = p.phoneme;
              chip.title = `${p.count} occurrence${p.count === 1 ? '' : 's'} · acquired age ${p.acquisitionAge}`;
              chip.textContent = `/${p.phoneme}/`;
              ph.appendChild(chip);
            }
            li.append(label, ph);
            phonList.appendChild(li);
          }
        }

        // Show/hide the "Clear" button based on whether anything is active.
        const clearBtn = byId('phon-clear');
        if (clearBtn) clearBtn.hidden = activePhonemes.size === 0;
      }

      function renderPerSpread(profile: ReadabilityProfile): void {
        const list = byId('per-spread-list');
        if (!list) return;
        list.innerHTML = '';
        for (const sp of profile.perSpread) {
          const num = document.createElement('span');
          num.className = 'ps-num';
          num.textContent = String(sp.index);

          const bar = document.createElement('div');
          bar.className = 'ps-bar';
          const fill = document.createElement('div');
          fill.className = 'ps-bar-fill';
          if (sp.wordCountCeiling === 0) {
            fill.classList.add('wordless');
          } else {
            const ratio = sp.wordCount / sp.wordCountCeiling;
            fill.style.width = `${Math.min(1, ratio) * 100}%`;
            if (ratio > 1) fill.classList.add('over');
            else if (ratio > 0.8) fill.classList.add('approaching');
          }
          bar.appendChild(fill);

          const wc = document.createElement('span');
          const isOver =
            sp.wordCountCeiling > 0 && sp.wordCount > sp.wordCountCeiling;
          if (sp.wordCountCeiling === 0) {
            wc.className = 'ps-wc wordless';
            wc.textContent = '— —';
          } else {
            wc.className = `ps-wc${isOver ? ' over' : ''}`;
            wc.textContent = `${sp.wordCount}/${sp.wordCountCeiling}`;
          }
          list.append(num, bar, wc);
        }
      }

      function renderTileWordCounts(profile: ReadabilityProfile): void {
        for (const sp of profile.perSpread) {
          const wcEl = document.querySelector(
            `[data-spread-wc="${sp.index}"]`,
          );
          const ceilingEl = document.querySelector(
            `[data-spread-ceiling="${sp.index}"]`,
          );
          const tile = document.querySelector(`[data-spread="${sp.index}"]`);
          if (wcEl) {
            wcEl.textContent = String(sp.wordCount);
            const isOver =
              sp.wordCountCeiling > 0 && sp.wordCount > sp.wordCountCeiling;
            wcEl.className = `spread-wc${isOver ? ' over' : ''}`;
          }
          if (ceilingEl) {
            ceilingEl.textContent =
              sp.wordCountCeiling > 0 ? `/ ${sp.wordCountCeiling}` : 'wordless';
          }
          if (tile) {
            tile.classList.toggle('has-warning', sp.warnings.length > 0);
            tile.classList.toggle('wordless', sp.wordCountCeiling === 0);
          }
        }
      }

      function renderReachWords(reach: ReachWord[]): void {
        const list = byId('reach-list');
        const empty = byId('reach-empty');
        if (!list || !empty) return;
        list.innerHTML = '';
        if (reach.length === 0) {
          empty.style.display = '';
          return;
        }
        empty.style.display = 'none';
        for (const r of reach) {
          const li = document.createElement('li');
          const word = document.createElement('span');
          word.className = 'word';
          word.textContent = r.word;
          const at = document.createElement('span');
          at.className = 'at';
          at.textContent = `spread ${r.spread}`;
          li.append(word, at);
          list.appendChild(li);
        }
      }

      function renderWarnings(profile: ReadabilityProfile): void {
        const list = byId('warning-list');
        const empty = byId('warnings-empty');
        if (!list || !empty) return;
        const all: Warning[] = [...profile.warnings];
        for (const sp of profile.perSpread) all.push(...sp.warnings);
        list.innerHTML = '';
        if (all.length === 0) {
          empty.style.display = '';
          return;
        }
        empty.style.display = 'none';
        for (const w of all) {
          const li = document.createElement('li');
          li.className = w.severity;
          const code = document.createElement('span');
          code.className = 'code';
          code.textContent = w.code;
          const msg = document.createElement('span');
          msg.textContent =
            w.spread !== undefined ? `[spread ${w.spread}] ${w.message}` : w.message;
          li.append(code, msg);
          list.appendChild(li);
        }
      }

      function updatePageWordCounts(web: WebManuscript): void {
        for (const sp of web.spreads) {
          for (const side of ['left', 'right'] as const) {
            const page = side === 'left' ? sp.leftPage : sp.rightPage;
            const count = (page.text.match(/\S+/g) ?? []).length;
            const el = document.querySelector(
              `[data-page-wc="${sp.index}-${side}"]`,
            );
            if (el) el.textContent = count === 0 ? '' : String(count);
          }
        }
      }

      function markEmptySpreads(web: WebManuscript): void {
        for (const sp of web.spreads) {
          const isEmpty =
            !sp.leftPage.text.trim() &&
            !sp.rightPage.text.trim() &&
            sp.leftPage.placement === 'text-only' &&
            sp.rightPage.placement === 'text-only';
          const tile = document.querySelector(`[data-spread="${sp.index}"]`);
          tile?.classList.toggle('empty', isEmpty);
        }
      }

      function updateStatusBar(profile: ReadabilityProfile): void {
        const w = byId('sb-words');
        const t = byId('sb-target');
        const s = byId('sb-sight');
        const sp = byId('sb-spreads');
        const wa = byId('sb-warnings');
        if (w) {
          w.textContent = String(profile.wordCount);
          let cls = '';
          if (profile.wordCount > profile.wordCountTarget.max) cls = 'over';
          else if (
            profile.wordCountTarget.min > 0 &&
            profile.wordCount < profile.wordCountTarget.min
          )
            cls = 'under';
          w.className = `status-val ${cls}`.trim();
        }
        if (t) {
          t.textContent =
            profile.wordCountTarget.min > 0
              ? `/ ${profile.wordCountTarget.min}–${profile.wordCountTarget.max}`
              : `/ ${profile.wordCountTarget.max}`;
        }
        if (s) {
          s.textContent = `${(profile.vocabulary.sightWordCoverage * 100).toFixed(0)}%`;
        }
        if (sp) {
          sp.textContent = String(
            profile.perSpread.filter((p) => p.wordCount > 0).length,
          );
        }
        const dc = byId('sb-decode');
        if (dc) {
          dc.textContent =
            profile.wordCount === 0
              ? '—'
              : `${(profile.phonology.decodabilityScore * 100).toFixed(0)}%`;
          dc.className = 'status-val';
        }
        if (wa) {
          const all =
            profile.warnings.length +
            profile.perSpread.reduce((acc, p) => acc + p.warnings.length, 0);
          wa.textContent = String(all);
          wa.className = `status-val${all > 0 ? ' over' : ''}`;
        }
      }

      function escapeRegex(s: string): string {
        return s.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
      }

      // Active phonemes — words containing any of these get a tinted
      // background highlight via CSS Custom Highlight API.
      const activePhonemes = new Set<string>();
      // Cache word → phoneme set so we don't repeat getWordPhonemes()
      // across analyses. Cleared lazily — words drop out of the cache
      // when the editor's vocabulary changes.
      const wordPhonemeCache = new Map<string, ReadonlySet<string>>();

      function wordContainsActivePhoneme(word: string): boolean {
        if (activePhonemes.size === 0) return false;
        const lower = word.toLowerCase();
        let set = wordPhonemeCache.get(lower);
        if (!set) {
          set = new Set(getWordPhonemes(lower));
          wordPhonemeCache.set(lower, set);
        }
        for (const p of activePhonemes) {
          if (set.has(p)) return true;
        }
        return false;
      }

      function applyPhonemeHighlights(): void {
        const HighlightCtor = (window as unknown as {
          Highlight?: new (...ranges: Range[]) => unknown;
        }).Highlight;
        const highlights = (CSS as unknown as {
          highlights?: Map<string, unknown>;
        }).highlights;
        if (!HighlightCtor || !highlights) return;

        if (activePhonemes.size === 0) {
          highlights.delete('phoneme-match');
          return;
        }

        const ranges: Range[] = [];
        const surface = byId('editor-surface');
        if (!surface) return;
        const wordRegex = /[A-Za-zÀ-ɏ]+(?:['’][A-Za-z]+)?/g;
        const editors = surface.querySelectorAll('.page-editor-editable');
        for (const editor of editors) {
          const walker = document.createTreeWalker(
            editor,
            NodeFilter.SHOW_TEXT,
          );
          let node: Node | null;
          while ((node = walker.nextNode())) {
            const text = node.textContent ?? '';
            wordRegex.lastIndex = 0;
            let m: RegExpExecArray | null;
            while ((m = wordRegex.exec(text)) !== null) {
              if (!wordContainsActivePhoneme(m[0])) continue;
              const range = new Range();
              range.setStart(node, m.index);
              range.setEnd(node, m.index + m[0].length);
              ranges.push(range);
            }
          }
        }

        const highlight = new HighlightCtor(...ranges);
        highlights.set('phoneme-match', highlight);
      }

      /**
       * Paint reach-word highlights inside every page editor using the
       * CSS Custom Highlight API. No DOM modification — the highlight
       * is a separate paint layer the browser draws over arbitrary
       * Range objects. Re-applied after every analyze() pass.
       *
       * Falls back silently in browsers without the API.
       */
      function applyReachWordHighlights(profile: ReadabilityProfile): void {
        const HighlightCtor = (window as unknown as {
          Highlight?: new (...ranges: Range[]) => unknown;
        }).Highlight;
        const highlights = (CSS as unknown as {
          highlights?: Map<string, unknown>;
        }).highlights;
        if (!HighlightCtor || !highlights) return;

        if (profile.reachWords.length === 0) {
          highlights.delete('reach-word');
          return;
        }

        const reachWords = Array.from(
          new Set(profile.reachWords.map((r) => r.word.toLowerCase())),
        );
        const pattern = new RegExp(
          `\\b(?:${reachWords.map(escapeRegex).join('|')})\\b`,
          'gi',
        );

        const ranges: Range[] = [];
        const surface = byId('editor-surface');
        if (!surface) return;
        const editors = surface.querySelectorAll('.page-editor-editable');
        for (const editor of editors) {
          const walker = document.createTreeWalker(
            editor,
            NodeFilter.SHOW_TEXT,
          );
          let node: Node | null;
          while ((node = walker.nextNode())) {
            const text = node.textContent ?? '';
            pattern.lastIndex = 0;
            let m: RegExpExecArray | null;
            while ((m = pattern.exec(text)) !== null) {
              const range = new Range();
              range.setStart(node, m.index);
              range.setEnd(node, m.index + m[0].length);
              ranges.push(range);
            }
          }
        }

        const highlight = new HighlightCtor(...ranges);
        highlights.set('reach-word', highlight);
      }

      function runAnalysis(): void {
        const web = readManuscript();
        const engine = toEngineManuscript(web);
        const profile = analyze(engine);
        // Vocabulary may have shifted — bust the per-word cache.
        wordPhonemeCache.clear();
        markEmptySpreads(web);
        updatePageWordCounts(web);
        renderTopMetrics(profile);
        renderPhonologyDetail(profile);
        renderTileWordCounts(profile);
        renderPerSpread(profile);
        renderReachWords(profile.reachWords);
        renderWarnings(profile);
        updateStatusBar(profile);
        applyReachWordHighlights(profile);
        applyPhonemeHighlights();
      }

      let debounceTimer: number | null = null;
      function scheduleAnalysis(): void {
        if (debounceTimer !== null) window.clearTimeout(debounceTimer);
        debounceTimer = window.setTimeout(runAnalysis, DEBOUNCE_MS);
      }

      document.addEventListener('input', (e) => {
        const t = e.target as HTMLElement | null;
        if (!t) return;
        if (t.id === 'age-band' || t.id === 'trim-size') {
          scheduleAnalysis();
        }
      });

      // Lexical editors dispatch this on every editor-state change;
      // covers typing, paste, undo/redo, programmatic setText.
      document.addEventListener('page-text-change', () => {
        scheduleAnalysis();
      });

      // Each PageEditor announces itself on mount. The first hydration
      // triggers a debounced analysis; the rest coalesce into the same
      // tick. After ~250 ms the analysis sees all 32 editors ready.
      document.addEventListener('page-editor-ready', () => {
        scheduleAnalysis();
      });

      document.addEventListener('change', (e) => {
        const t = e.target as HTMLElement | null;
        if (!t) return;
        if (t.matches?.('.page-placement')) {
          const page = t.closest('.page');
          if (page) {
            page.setAttribute(
              'data-placement',
              (t as HTMLSelectElement).value,
            );
          }
          runAnalysis();
        } else if (t.id === 'age-band' || t.id === 'trim-size') {
          if (t.id === 'trim-size') applyTrimAspect();
          runAnalysis();
        }
      });

      function setPage(
        spread: number,
        side: 'left' | 'right',
        text: string,
        placement: PagePlacement,
      ): void {
        const handle = (window as unknown as {
          __pageEditors?: Record<string, { setText: (s: string) => void }>;
        }).__pageEditors?.[`${spread}-${side}`];
        handle?.setText(text);
        const sel = document.querySelector(
          `[data-page-placement="${spread}-${side}"]`,
        ) as HTMLSelectElement | null;
        const page = document.querySelector(`[data-page="${spread}-${side}"]`);
        if (sel) sel.value = placement;
        page?.setAttribute('data-placement', placement);
      }

      function loadSample(key: string): void {
        const sample = SAMPLES[key];
        if (!sample) return;
        const ageSel = byId('age-band') as HTMLSelectElement | null;
        if (ageSel) ageSel.value = sample.ageBand;
        const spreads = sample.text
          .split(/\n\s*\n/)
          .map((s) => s.trim())
          .filter((s) => s.length > 0);
        for (let i = 1; i <= SPREAD_COUNT; i++) {
          const text = spreads[i - 1] ?? '';
          // Convention: load all of the spread's text onto the left page;
          // right page becomes a full-bleed illustration when the spread
          // has any text, otherwise both pages are blank text-only.
          setPage(i, 'left', text, 'text-only');
          setPage(i, 'right', '', text ? 'illustration-only' : 'text-only');
        }
        runAnalysis();
      }

      byId('sample-loader')?.addEventListener('change', (e) => {
        const sel = e.target as HTMLSelectElement;
        if (sel.value) {
          loadSample(sel.value);
          sel.value = '';
        }
      });

      byId('body-font')?.addEventListener('change', applyBodyFont);

      byId('layout-preset')?.addEventListener('change', (e) => {
        const sel = e.target as HTMLSelectElement;
        if (sel.value) {
          applyLayoutPreset(sel.value);
          sel.value = '';
        }
      });

      byId('sidebar-toggle')?.addEventListener('click', () => {
        const collapsed = document.body.classList.toggle('sidebar-collapsed');
        const btn = byId('sidebar-toggle');
        if (btn) btn.textContent = collapsed ? 'Show' : 'Hide';
      });

      // Phoneme chip clicks (event delegation — chips are re-rendered
      // on every analyze pass, so binding per-element would leak).
      byId('phoneme-by-age')?.addEventListener('click', (e) => {
        const target = e.target as HTMLElement | null;
        const chip = target?.closest?.('.phon-chip') as HTMLElement | null;
        if (!chip) return;
        const phoneme = chip.dataset.phoneme;
        if (!phoneme) return;
        if (activePhonemes.has(phoneme)) {
          activePhonemes.delete(phoneme);
        } else {
          activePhonemes.add(phoneme);
        }
        chip.classList.toggle('active', activePhonemes.has(phoneme));
        const clearBtn = byId('phon-clear');
        if (clearBtn) clearBtn.hidden = activePhonemes.size === 0;
        applyPhonemeHighlights();
      });

      byId('phon-clear')?.addEventListener('click', () => {
        activePhonemes.clear();
        document.querySelectorAll('.phon-chip.active').forEach((el) =>
          el.classList.remove('active'),
        );
        const clearBtn = byId('phon-clear');
        if (clearBtn) clearBtn.hidden = true;
        applyPhonemeHighlights();
      });

      // ---- find & replace ----
      interface FindMatch {
        spread: number;
        side: 'left' | 'right';
        index: number;
        length: number;
      }
      let findMatches: FindMatch[] = [];
      let findCurrent = -1;

      function getFindHighlightAPIs() {
        const HighlightCtor = (window as unknown as {
          Highlight?: new (...ranges: Range[]) => unknown;
        }).Highlight;
        const highlights = (CSS as unknown as {
          highlights?: Map<string, unknown>;
        }).highlights;
        return { HighlightCtor, highlights };
      }

      function rangeForMatch(m: FindMatch): Range | null {
        const pageEl = document.querySelector(
          `[data-page="${m.spread}-${m.side}"] .page-editor-editable`,
        );
        if (!pageEl) return null;
        const walker = document.createTreeWalker(pageEl, NodeFilter.SHOW_TEXT);
        let offset = 0;
        let startNode: Node | null = null;
        let startOff = 0;
        let endNode: Node | null = null;
        let endOff = 0;
        let node: Node | null;
        const target = m.index;
        const endTarget = m.index + m.length;
        while ((node = walker.nextNode())) {
          const len = node.textContent?.length ?? 0;
          if (!startNode && offset + len > target) {
            startNode = node;
            startOff = target - offset;
          }
          if (offset + len >= endTarget) {
            endNode = node;
            endOff = endTarget - offset;
            break;
          }
          offset += len;
        }
        if (!startNode || !endNode) return null;
        const range = new Range();
        range.setStart(startNode, startOff);
        range.setEnd(endNode, endOff);
        return range;
      }

      function computeFindMatches(query: string): FindMatch[] {
        if (!query) return [];
        const editors = (window as unknown as {
          __pageEditors?: Record<string, { getText: () => string }>;
        }).__pageEditors;
        if (!editors) return [];
        const re = new RegExp(escapeRegex(query), 'gi');
        const out: FindMatch[] = [];
        for (let i = 1; i <= SPREAD_COUNT; i++) {
          for (const side of ['left', 'right'] as const) {
            const text = editors[`${i}-${side}`]?.getText() ?? '';
            if (!text) continue;
            re.lastIndex = 0;
            let m: RegExpExecArray | null;
            while ((m = re.exec(text)) !== null) {
              out.push({ spread: i, side, index: m.index, length: m[0].length });
            }
          }
        }
        return out;
      }

      function renderFindHighlights(): void {
        const { HighlightCtor, highlights } = getFindHighlightAPIs();
        if (!HighlightCtor || !highlights) return;
        highlights.delete('find-match');
        highlights.delete('find-current');
        if (findMatches.length === 0) return;
        const allRanges: Range[] = [];
        let currentRange: Range | null = null;
        findMatches.forEach((m, i) => {
          const r = rangeForMatch(m);
          if (!r) return;
          if (i === findCurrent) currentRange = r;
          else allRanges.push(r);
        });
        if (allRanges.length > 0) {
          highlights.set('find-match', new HighlightCtor(...allRanges));
        }
        if (currentRange) {
          highlights.set('find-current', new HighlightCtor(currentRange));
        }
      }

      function updateFindCount(): void {
        const el = byId('find-count');
        if (!el) return;
        if (findMatches.length === 0) {
          el.textContent = byId('find-input') instanceof HTMLInputElement && (byId('find-input') as HTMLInputElement).value
            ? 'no matches'
            : '—';
        } else {
          el.textContent = `${findCurrent + 1} of ${findMatches.length}`;
        }
        const prev = byId('find-prev') as HTMLButtonElement | null;
        const next = byId('find-next') as HTMLButtonElement | null;
        const repl = byId('find-replace') as HTMLButtonElement | null;
        const replAll = byId('find-replace-all') as HTMLButtonElement | null;
        const disable = findMatches.length === 0;
        [prev, next, repl, replAll].forEach((b) => {
          if (b) b.disabled = disable;
        });
      }

      function scrollToCurrent(): void {
        if (findCurrent < 0) return;
        const r = rangeForMatch(findMatches[findCurrent]);
        if (!r) return;
        const rect = r.getBoundingClientRect();
        const el = r.startContainer.parentElement;
        // scrollIntoView on a Range isn't standard; ride on the parent.
        if (el && rect) {
          el.scrollIntoView({
            block: 'nearest',
            inline: 'nearest',
            behavior: 'smooth',
          });
        }
      }

      function refreshFind(): void {
        const input = byId('find-input') as HTMLInputElement | null;
        const query = input?.value ?? '';
        const prev = findCurrent >= 0 ? findMatches[findCurrent] : null;
        findMatches = computeFindMatches(query);
        if (findMatches.length === 0) {
          findCurrent = -1;
        } else if (prev) {
          // Try to keep the cursor near where it was.
          const idx = findMatches.findIndex(
            (m) =>
              m.spread > prev.spread ||
              (m.spread === prev.spread &&
                (m.side === 'right' && prev.side === 'left' ? true : m.index >= prev.index)),
          );
          findCurrent = idx === -1 ? 0 : idx;
        } else {
          findCurrent = 0;
        }
        renderFindHighlights();
        updateFindCount();
      }

      function findStep(delta: number): void {
        if (findMatches.length === 0) return;
        findCurrent =
          (findCurrent + delta + findMatches.length) % findMatches.length;
        renderFindHighlights();
        updateFindCount();
        scrollToCurrent();
      }

      function replaceCurrent(): void {
        if (findCurrent < 0 || findMatches.length === 0) return;
        const m = findMatches[findCurrent];
        const replInput = byId('replace-input') as HTMLInputElement | null;
        const replacement = replInput?.value ?? '';
        const handle = (window as unknown as {
          __pageEditors?: Record<string, { getText: () => string; setText: (t: string) => void }>;
        }).__pageEditors?.[`${m.spread}-${m.side}`];
        if (!handle) return;
        const text = handle.getText();
        const next = text.slice(0, m.index) + replacement + text.slice(m.index + m.length);
        handle.setText(next);
        // refreshFind will fire after Lexical's OnChangePlugin + the
        // debounced analyze pass; do an immediate pass too so the
        // count is accurate right after the click.
        setTimeout(() => {
          refreshFind();
          // Stay at the same logical position (current may now point at
          // the next match in the same spot since we just consumed one).
        }, 0);
      }

      function replaceAll(): void {
        if (findMatches.length === 0) return;
        const replInput = byId('replace-input') as HTMLInputElement | null;
        const replacement = replInput?.value ?? '';
        const editors = (window as unknown as {
          __pageEditors?: Record<string, { getText: () => string; setText: (t: string) => void }>;
        }).__pageEditors;
        if (!editors) return;
        // Group matches by page so we can rebuild each page's text once.
        const byPage = new Map<string, FindMatch[]>();
        for (const m of findMatches) {
          const key = `${m.spread}-${m.side}`;
          const arr = byPage.get(key) ?? [];
          arr.push(m);
          byPage.set(key, arr);
        }
        for (const [key, matches] of byPage) {
          const handle = editors[key];
          if (!handle) continue;
          let text = handle.getText();
          // Iterate matches in reverse so earlier offsets stay valid.
          for (let i = matches.length - 1; i >= 0; i--) {
            const m = matches[i];
            text = text.slice(0, m.index) + replacement + text.slice(m.index + m.length);
          }
          handle.setText(text);
        }
        setTimeout(() => {
          refreshFind();
        }, 0);
      }

      function openFindBar(): void {
        const bar = byId('find-bar');
        if (!bar) return;
        bar.hidden = false;
        const input = byId('find-input') as HTMLInputElement | null;
        input?.focus();
        input?.select();
      }

      function closeFindBar(): void {
        const bar = byId('find-bar');
        if (!bar) return;
        bar.hidden = true;
        findMatches = [];
        findCurrent = -1;
        const { highlights } = getFindHighlightAPIs();
        if (highlights) {
          highlights.delete('find-match');
          highlights.delete('find-current');
        }
      }

      document.addEventListener('keydown', (e) => {
        // Cmd/Ctrl+F → open find bar (suppress browser default).
        if ((e.metaKey || e.ctrlKey) && e.key === 'f' && !e.shiftKey) {
          e.preventDefault();
          openFindBar();
        }
      });

      byId('find-input')?.addEventListener('input', refreshFind);
      byId('find-input')?.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') {
          e.preventDefault();
          findStep(e.shiftKey ? -1 : 1);
        } else if (e.key === 'Escape') {
          e.preventDefault();
          closeFindBar();
        }
      });
      byId('replace-input')?.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
          e.preventDefault();
          closeFindBar();
        } else if (e.key === 'Enter') {
          e.preventDefault();
          replaceCurrent();
        }
      });
      byId('find-prev')?.addEventListener('click', () => findStep(-1));
      byId('find-next')?.addEventListener('click', () => findStep(1));
      byId('find-replace')?.addEventListener('click', replaceCurrent);
      byId('find-replace-all')?.addEventListener('click', replaceAll);
      byId('find-close')?.addEventListener('click', closeFindBar);

      byId('reset-btn')?.addEventListener('click', () => {
        for (let i = 1; i <= SPREAD_COUNT; i++) {
          setPage(i, 'left', '', 'text-only');
          setPage(i, 'right', '', 'text-only');
        }
        runAnalysis();
      });

      // ---- view mode (grid / book) ----
      const ASPECT_BY_TRIM: Record<string, number> = {
        STANDARD_PORTRAIT: 1.6,
        STANDARD_LANDSCAPE: 2.5,
        SQUARE: 2.0,
      };

      function applyTrimAspect(): void {
        const trimSel = byId('trim-size') as HTMLSelectElement | null;
        const key = trimSel?.value ?? 'STANDARD_PORTRAIT';
        document.documentElement.style.setProperty(
          '--spread-aspect',
          String(ASPECT_BY_TRIM[key] ?? 1.6),
        );
      }

      // ---- body font ----
      const FONTS: Record<string, { family: string; weight: number }> = {
        caslon: {
          family: '"Libre Caslon Text", Georgia, serif',
          weight: 400,
        },
        futura: {
          family: '"Futura", "Futura PT", "Trebuchet MS", system-ui, sans-serif',
          weight: 400,
        },
        'futura-bold': {
          family: '"Futura", "Futura PT", "Trebuchet MS", system-ui, sans-serif',
          weight: 700,
        },
        atkinson: {
          family: '"Atkinson Hyperlegible", system-ui, sans-serif',
          weight: 400,
        },
        bricolage: {
          family: '"Bricolage Grotesque", system-ui, sans-serif',
          weight: 400,
        },
      };

      function applyBodyFont(): void {
        const sel = byId('body-font') as HTMLSelectElement | null;
        const key = sel?.value ?? 'caslon';
        const font = FONTS[key] ?? FONTS.caslon;
        document.documentElement.style.setProperty(
          '--body-font-family',
          font.family,
        );
        document.documentElement.style.setProperty(
          '--body-font-weight',
          String(font.weight),
        );
      }

      // ---- layout presets ----
      // Presets only touch placements, never text content.
      type Placements = { left: PagePlacement; right: PagePlacement };
      const LAYOUT_PRESETS: Record<string, (idx: number) => Placements> = {
        classic: () => ({ left: 'text-only', right: 'illustration-only' }),
        mirror: (i) =>
          i % 2 === 1
            ? { left: 'text-only', right: 'illustration-only' }
            : { left: 'illustration-only', right: 'text-only' },
        'text-top': () => ({ left: 'text-top', right: 'text-top' }),
        'full-text': () => ({ left: 'text-only', right: 'text-only' }),
      };

      function setPlacement(
        spread: number,
        side: 'left' | 'right',
        placement: PagePlacement,
      ): void {
        const sel = document.querySelector(
          `[data-page-placement="${spread}-${side}"]`,
        ) as HTMLSelectElement | null;
        const page = document.querySelector(`[data-page="${spread}-${side}"]`);
        if (sel) sel.value = placement;
        page?.setAttribute('data-placement', placement);
      }

      function applyLayoutPreset(key: string): void {
        const fn = LAYOUT_PRESETS[key];
        if (!fn) return;
        for (let i = 1; i <= SPREAD_COUNT; i++) {
          const { left, right } = fn(i);
          setPlacement(i, 'left', left);
          setPlacement(i, 'right', right);
        }
        runAnalysis();
      }

      function currentSpreadIndex(): number {
        const surface = byId('editor-surface');
        if (!surface || surface.getAttribute('data-view') !== 'book') return 0;
        const tiles = surface.querySelectorAll<HTMLElement>('.spread');
        const surfRect = surface.getBoundingClientRect();
        let bestIdx = 0;
        let bestVisible = 0;
        tiles.forEach((tile, i) => {
          const r = tile.getBoundingClientRect();
          const v = Math.max(
            0,
            Math.min(r.right, surfRect.right) - Math.max(r.left, surfRect.left),
          );
          if (v > bestVisible) {
            bestVisible = v;
            bestIdx = i;
          }
        });
        return bestIdx;
      }

      function updateSpreadCounter(): void {
        const counter = byId('spread-counter');
        const prevBtn = byId('nav-prev') as HTMLButtonElement | null;
        const nextBtn = byId('nav-next') as HTMLButtonElement | null;
        if (!counter) return;
        const idx = currentSpreadIndex();
        counter.textContent = `Spread ${idx + 1} of ${SPREAD_COUNT}`;
        if (prevBtn) prevBtn.disabled = idx <= 0;
        if (nextBtn) nextBtn.disabled = idx >= SPREAD_COUNT - 1;
      }

      function scrollToSpread(idx: number): void {
        const clamped = Math.max(0, Math.min(SPREAD_COUNT - 1, idx));
        const tile = document.querySelector(`[data-spread="${clamped + 1}"]`);
        tile?.scrollIntoView({
          block: 'nearest',
          inline: 'center',
          behavior: 'smooth',
        });
      }

      function setViewMode(mode: 'grid' | 'book'): void {
        const surface = byId('editor-surface');
        if (!surface) return;
        surface.setAttribute('data-view', mode);
        document.body.classList.toggle('book-mode', mode === 'book');
        for (const btn of document.querySelectorAll<HTMLButtonElement>(
          '[data-view-set]',
        )) {
          btn.classList.toggle('active', btn.dataset.viewSet === mode);
        }
        if (mode === 'book') {
          requestAnimationFrame(() => {
            const first = document.querySelector('[data-spread="1"]');
            first?.scrollIntoView({ block: 'nearest', inline: 'center' });
            updateSpreadCounter();
          });
        }
      }

      for (const btn of document.querySelectorAll<HTMLButtonElement>(
        '[data-view-set]',
      )) {
        btn.addEventListener('click', () => {
          setViewMode(btn.dataset.viewSet as 'grid' | 'book');
        });
      }

      byId('nav-prev')?.addEventListener('click', () => {
        scrollToSpread(currentSpreadIndex() - 1);
      });
      byId('nav-next')?.addEventListener('click', () => {
        scrollToSpread(currentSpreadIndex() + 1);
      });

      document.addEventListener('keydown', (e) => {
        if (!document.body.classList.contains('book-mode')) return;
        const active = document.activeElement;
        const tag = active?.tagName;
        if (tag === 'TEXTAREA' || tag === 'INPUT' || tag === 'SELECT') return;
        if (e.key === 'ArrowLeft') {
          scrollToSpread(currentSpreadIndex() - 1);
          e.preventDefault();
        } else if (e.key === 'ArrowRight') {
          scrollToSpread(currentSpreadIndex() + 1);
          e.preventDefault();
        }
      });

      byId('editor-surface')?.addEventListener('scroll', () => {
        if (document.body.classList.contains('book-mode')) updateSpreadCounter();
      });

      applyTrimAspect();
      applyBodyFont();
      runAnalysis();
    </script>
  </body>
</html>
