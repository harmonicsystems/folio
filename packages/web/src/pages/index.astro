      <button type="button" id="find-close" class="find-bar-close" title="Close (Esc)" aria-label="Close">×</button>
    </div>

    <main class="workspace">
      <section
        class="editor-surface"
        id="editor-surface"
        aria-label="Manuscript spreads"
      >
        {Array.from({ length: SPREAD_COUNT }, (_, i) => i + 1).map((index) => (
          <article class="spread" data-spread={index}>
            <header class="spread-header">
              <span class="spread-number">Spread {index}</span>
            </header>
            <div class="spread-pages">
              {(['left', 'right'] as const).map((side) => (
                <div
                  class={`page page-${side}`}
                  data-page={`${index}-${side}`}
