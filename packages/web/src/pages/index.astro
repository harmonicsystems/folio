    <div class="status-bar" id="status-bar" aria-live="polite">
      <span class="status-item">
        <span class="status-label">Words</span>
        <span class="status-val" id="sb-words">0</span>
        <span class="status-sub" id="sb-target">/ —</span>
      </span>
