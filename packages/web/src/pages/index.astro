        </label>
        <label class="control">
          <span class="control-label">Body font</span>
          <select id="body-font">
            <option value="caslon" selected>Libre Caslon</option>
            <option value="futura">Futura</option>
            <option value="futura-bold">Futura Bold</option>
            <option value="atkinson">Atkinson Hyperlegible</option>
            <option value="bricolage">Bricolage Grotesque</option>
