        </label>
        <label class="control">
          <span class="control-label">Layout</span>
          <select id="layout-preset">
            <option value="">— preset —</option>
            <option value="classic">Classic facing</option>
            <option value="mirror">Mirror</option>
            <option value="text-top">Text top</option>
