---
import { readFileSync } from 'node:fs';
import { dirname, resolve } from 'node:path';
import { fileURLToPath } from 'node:url';
import type { AgeBand } from '@harmonic-systems/early-literacy';
import StudioApp from '../components/StudioApp.tsx';

const __dirname = dirname(fileURLToPath(import.meta.url));
const CORPORA = resolve(__dirname, '../../../../corpora');
const DEMOS = resolve(__dirname, '../../demo-fixtures');
const loadCorpus = (slug: string) =>
  readFileSync(`${CORPORA}/${slug}.txt`, 'utf8');
const loadDemo = (slug: string) =>
  readFileSync(`${DEMOS}/${slug}.txt`, 'utf8');

interface Sample {
  ageBand: AgeBand;
  label: string;
  text: string;
}

const samples: Record<string, Sample> = {
  board: {
    ageBand: 'board',
    label: 'Board · Time for Bed, Little One',
    text: loadDemo('board-time-for-bed'),
  },
  'early-picture': {
    ageBand: 'early-picture',
    label: 'Early picture · Lear, 1871',
    text: loadCorpus('owl-and-pussycat'),
  },
  picture: {
    ageBand: 'picture',
    label: 'Picture · Potter, 1902',
    text: loadCorpus('peter-rabbit'),
  },
  'early-reader': {
    ageBand: 'early-reader',
    label: 'Early reader · Aesop, 1912',
    text: loadCorpus('aesop-selected'),
  },
  chapter: {
    ageBand: 'chapter',
    label: 'Chapter · Baum, 1900',
    text: loadCorpus('wizard-of-oz-opening'),
  },
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="A local-first picture-book studio that shows the words, sounds, and read-aloud patterns already present in your manuscript."
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href="https://folio.harmonic-systems.org/" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Folio" />
    <meta property="og:title" content="Folio — the language inside your picture book" />
    <meta
      property="og:description"
      content="See the words, sounds, and rhythm already present in your picture-book manuscript. Folio observes; the writer decides."
    />
    <meta property="og:url" content="https://folio.harmonic-systems.org/" />
    <meta name="twitter:card" content="summary" />
    <title>Folio — picture-book studio</title>
    <script
      is:inline
      defer
      data-domain="folio.harmonic-systems.org"
      src="https://plausible.io/js/script.js"
    ></script>
  </head>
  <body>
    <StudioApp client:load samples={samples} />
  </body>
</html>
